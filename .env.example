# Firebase Service Account Key (from Firebase Console)
# Get this from: Firebase Console → Project Settings → Service Accounts → Generate New Private Key
# Option 1: Paste the entire JSON as a single string (recommended for Railway)
FIREBASE_KEY='{"type":"service_account","project_id":"your-project-id","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}'

# Option 2: Base64 encoded version of the service account JSON
# FIREBASE_KEY_BASE64=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50IiwicHJvamVjdF9pZCI6I...

# (Optional) Client URL for CORS (defaults to '*' for development)
CLIENT_URL=https://your-frontend-domain.com

# Server port (Railway will automatically set PORT, but you can override)
PORT=3000
